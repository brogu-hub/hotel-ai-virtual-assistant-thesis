flowchart TB
    subgraph CFG["Collection Config"]
        direction TB
        C1["name: hotel_knowledge"]
        C2["vectors.size: 4096"]
        C3["vectors.distance: Cosine"]
        C4["shard_number: 1"]
        C5["replication_factor: 1"]
        C6["on_disk_payload: true"]
        C7["payload_schema: empty (client-side filtering)"]
    end

    subgraph HNSW["hnsw_config"]
        direction TB
        H1["m: 16"]
        H2["ef_construct: 100"]
        H3["full_scan_threshold: 10000"]
        H4["on_disk: false"]
    end

    subgraph OPT["optimizer_config"]
        direction TB
        O1["deleted_threshold: 0.2"]
